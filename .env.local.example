# ==========================================
# CONFIGURACIÓN DE VARIABLES DE ENTORNO
# Duplica este archivo como '.env.local' y completa las credenciales
# ==========================================

# 1. Supabase (Credenciales del Proyecto)
# Búscalas en: Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-aqui
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-aqui

# 2a. Opción A: IA Local con Ollama (GRATIS, SIN API KEY)
# Si tienes Ollama instalado, deja OPENROUTER_API_KEY vacío
# Instala los modelos: ollama pull qwen2.5-coder:32b && ollama pull qwen2.5-coder:7b
# Inicia el servidor: ollama serve
# Ver guía completa: OLLAMA-SETUP.md
OLLAMA_BASE_URL=http://localhost:11434

# 2b. Opción B: IA en la Nube con OpenRouter (REQUIERE PAGO)
# Crea una cuenta en: https://openrouter.ai/
# Genera una API Key en: https://openrouter.ai/keys
# Añade créditos ($5-10 USD para empezar)
# El runner usa:
#   - Claude Sonnet 4 para Architect (razonamiento)
#   - Qwen 2.5 Coder 32B para Workers (codificación)
# OPENROUTER_API_KEY=sk-or-v1-tu-clave-aqui

# NOTA: Si tienes ambos configurados, el sistema intentará:
# 1. Ollama primero (gratis, local)
# 2. OpenRouter como fallback (si Ollama falla)
# 3. Respuesta estática de emergencia (si ambos fallan)

# 3. URL de la Aplicación (Dashboard)
# Usada por redireccionamientos de Auth y Webhooks
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 4. GitHub Integration (OPCIONAL - Para Fase 2)
# Genera un Personal Access Token en: https://github.com/settings/tokens
# Scopes necesarios: repo, workflow
# Permite crear Pull Requests automáticos
# GITHUB_TOKEN=ghp_tu-token-aqui
# GITHUB_ORG=tu-usuario-o-organizacion

# 5. Vercel Deploy (REQUERIDO PARA FASE 4)
# Genera un token en: https://vercel.com/account/tokens
# Org ID: Settings → General → Organization ID
# Permite deploys automáticos desde el runner
# VERCEL_TOKEN=tu-vercel-token-aqui
# VERCEL_ORG_ID=tu-org-id
# Para encontrar tu Org ID:
# 1. Ve a https://vercel.com/[tu-usuario]/settings
# 2. Copia el "Organization ID"


